{
  "name": "@davidwarshawsky/claude-code-router",
  "version": "2.0.0",
  "description": "Intelligent routing gateway for Claude Code - route requests to multiple LLM providers with scenario-based routing, multi-account support, and advanced transformations",
  "scripts": {
    "build": "pnpm build:shared && pnpm build:core && pnpm build:server && pnpm build:cli && pnpm build:ui",
    "build:core": "pnpm --filter @musistudio/llms build",
    "build:shared": "pnpm --filter @CCR/shared build",
    "build:cli": "pnpm --filter @CCR/cli build",
    "build:server": "pnpm --filter @CCR/server build",
    "build:ui": "pnpm --filter @CCR/ui build",
    "build:docs": "pnpm --filter claude-code-router-docs build",
    "pack:check": "npm pack --json --dry-run",
    "test:providers": "bash scripts/smoke-test-providers.sh",
    "release": "pnpm build && bash scripts/release.sh all",
    "release:npm": "bash scripts/release.sh npm",
    "release:docker": "bash scripts/release.sh docker",
    "dev:cli": "pnpm --filter @CCR/cli dev",
    "dev:server": "pnpm --filter @CCR/server dev",
    "dev:ui": "pnpm --filter @CCR/ui dev",
    "dev:core": "pnpm --filter @musistudio/llms dev",
    "dev:docs": "pnpm --filter claude-code-router-docs start",
    "serve:docs": "pnpm --filter claude-code-router-docs serve"
  },
  "bin": {
    "ccr": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "claude",
    "code",
    "router",
    "llm",
    "anthropic"
  ],
  "author": "davidwarshawsky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidwarshawsky/claude-code-router.git"
  },
  "homepage": "https://github.com/davidwarshawsky/claude-code-router",
  "bugs": {
    "url": "https://github.com/davidwarshawsky/claude-code-router/issues"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "esbuild": "^0.25.1",
    "shx": "^0.4.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
